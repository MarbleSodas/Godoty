{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Godoty Command Protocol",
  "description": "JSON-based command protocol for communication between Tauri app and Godot plugin",
  "definitions": {
    "CreateNodeCommand": {
      "type": "object",
      "required": ["action", "type", "name"],
      "properties": {
        "action": {
          "type": "string",
          "const": "create_node"
        },
        "type": {
          "type": "string",
          "description": "Godot node type (e.g., CharacterBody2D, Sprite2D, CollisionShape2D)"
        },
        "name": {
          "type": "string",
          "description": "Name for the new node"
        },
        "parent": {
          "type": ["string", "null"],
          "description": "Parent node path. Null means root or selected node"
        },
        "properties": {
          "type": "object",
          "description": "Properties to set on the node",
          "additionalProperties": true
        }
      }
    },
    "DeleteNodeCommand": {
      "type": "object",
      "required": ["action", "path"],
      "properties": {
        "action": {
          "type": "string",
          "const": "delete_node"
        },
        "path": {
          "type": "string",
          "description": "Node path to delete"
        }
      }
    },
    "ModifyNodeCommand": {
      "type": "object",
      "required": ["action", "path", "properties"],
      "properties": {
        "action": {
          "type": "string",
          "const": "modify_node"
        },
        "path": {
          "type": "string",
          "description": "Node path to modify"
        },
        "properties": {
          "type": "object",
          "description": "Properties to update",
          "additionalProperties": true
        }
      }
    },
    "AttachScriptCommand": {
      "type": "object",
      "required": ["action", "path", "script_content"],
      "properties": {
        "action": {
          "type": "string",
          "const": "attach_script"
        },
        "path": {
          "type": "string",
          "description": "Node path to attach script to"
        },
        "script_content": {
          "type": "string",
          "description": "GDScript code content"
        },
        "script_path": {
          "type": ["string", "null"],
          "description": "Optional file path to save the script"
        }
      }
    },
    "CreateSceneCommand": {
      "type": "object",
      "required": ["action", "name", "root_type"],
      "properties": {
        "action": {
          "type": "string",
          "const": "create_scene"
        },
        "name": {
          "type": "string",
          "description": "Scene name"
        },
        "root_type": {
          "type": "string",
          "description": "Root node type"
        },
        "save_path": {
          "type": ["string", "null"],
          "description": "Path to save the scene file"
        }
      }
    },
    "GetSceneInfoCommand": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": {
          "type": "string",
          "const": "get_scene_info"
        }
      }
    },

    "InspectSceneFileCommand": {
      "type": "object",
      "required": ["action", "path"],
      "properties": {
        "action": { "type": "string", "const": "inspect_scene_file" },
        "path": { "type": "string", "description": "Path to .tscn scene file (res:// or absolute)" }
      }
    },
    "GetCurrentSceneDetailedCommand": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "const": "get_current_scene_detailed" }
      }
    },
    "CaptureVisualContextCommand": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "const": "capture_visual_context" },
        "metadata": { "type": "object", "additionalProperties": true }
      }
    },
    "GetVisualSnapshotCommand": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "const": "get_visual_snapshot" }
      }
    },
    "EnableAutoVisualCaptureCommand": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "const": "enable_auto_visual_capture" }
      }
    },
    "DisableAutoVisualCaptureCommand": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "const": "disable_auto_visual_capture" }
      }
    },
    "StartDebugCaptureCommand": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "const": "start_debug_capture" }
      }
    },
    "StopDebugCaptureCommand": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "const": "stop_debug_capture" }
      }
    },
    "ClearDebugOutputCommand": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "const": "clear_debug_output" }
      }
    },
    "GetDebugOutputCommand": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "const": "get_debug_output" },
        "limit": { "type": "integer", "minimum": 1, "maximum": 1000, "default": 200 }
      }
    },
    "OpenSceneCommand": {"type":"object","required":["action","path"],"properties":{"action":{"type":"string","const":"open_scene"},"path":{"type":"string","description":"Path to .tscn scene file (res:// or absolute)"}}},
    "SelectNodesCommand": {"type":"object","required":["action","paths"],"properties":{"action":{"type":"string","const":"select_nodes"},"paths":{"type":"array","items":{"type":"string"},"description":"Array of node paths to select"}}},
    "FocusNodeCommand": {"type":"object","required":["action","path"],"properties":{"action":{"type":"string","const":"focus_node"},"path":{"type":"string","description":"Node path to focus in the editor"},"select":{"type":"boolean","default":true}}},
    "PlayCommand": {"type":"object","required":["action"],"properties":{"action":{"type":"string","const":"play"},"mode":{"type":"string","enum":["current","main","custom"],"default":"current"},"path":{"type":["string","null"],"description":"Scene path when mode=custom"}}},
    "AddCommandPaletteCommand": {"type":"object","required":["action","display_name","key","action_to_execute"],"properties":{"action":{"type":"string","const":"add_command_palette_command"},"display_name":{"type":"string"},"key":{"type":"string","description":"Unique key for the palette item"},"action_to_execute":{"type":"string","description":"Action to send when invoked"},"payload":{"type":"object","additionalProperties":true}}},
    "SearchNodesByTypeCommand": {"type":"object","required":["action","type"],"properties":{"action":{"type":"string","const":"search_nodes_by_type"},"type":{"type":"string","description":"Godot node type (e.g., Sprite2D)"},"select_results":{"type":"boolean","default":false},"focus_first":{"type":"boolean","default":false}}},
    "SearchNodesByNameCommand": {"type":"object","required":["action","name"],"properties":{"action":{"type":"string","const":"search_nodes_by_name"},"name":{"type":"string"},"exact":{"type":"boolean","default":false},"case_sensitive":{"type":"boolean","default":false},"select_results":{"type":"boolean","default":false},"focus_first":{"type":"boolean","default":false}}},
    "SearchNodesByGroupCommand": {"type":"object","required":["action","group"],"properties":{"action":{"type":"string","const":"search_nodes_by_group"},"group":{"type":"string"},"select_results":{"type":"boolean","default":false},"focus_first":{"type":"boolean","default":false}}},
    "SearchNodesByScriptCommand": {"type":"object","required":["action"],"properties":{"action":{"type":"string","const":"search_nodes_by_script"},"script_path":{"type":["string","null"],"description":"Filter by script path if provided"},"select_results":{"type":"boolean","default":false},"focus_first":{"type":"boolean","default":false}}},
    "DuplicateNodeCommand": {"type":"object","required":["action","path"],"properties":{"action":{"type":"string","const":"duplicate_node"},"path":{"type":"string"},"parent":{"type":["string","null"],"description":"New parent path or null to keep"},"name":{"type":["string","null"]}}},
    "ReparentNodeCommand": {"type":"object","required":["action","path","new_parent"],"properties":{"action":{"type":"string","const":"reparent_node"},"path":{"type":"string"},"new_parent":{"type":"string"},"index":{"type":"integer","minimum":-1,"default":-1},"keep_global_transform":{"type":"boolean","default":true}}},
    "RenameNodeCommand": {"type":"object","required":["action","path","new_name"],"properties":{"action":{"type":"string","const":"rename_node"},"path":{"type":"string"},"new_name":{"type":"string"}}},
    "AddToGroupCommand": {"type":"object","required":["action","path","group"],"properties":{"action":{"type":"string","const":"add_to_group"},"path":{"type":"string"},"group":{"type":"string"},"persistent":{"type":"boolean","default":true}}},
    "RemoveFromGroupCommand": {"type":"object","required":["action","path","group"],"properties":{"action":{"type":"string","const":"remove_from_group"},"path":{"type":"string"},"group":{"type":"string"}}},
    "Response": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error"]
        },
        "message": {
          "type": "string",
          "description": "Human-readable message"
        },
        "data": {
          "type": "object",
          "description": "Additional response data",
          "additionalProperties": true
        }
      }
    }
  },
  "oneOf": [
    { "$ref": "#/definitions/CreateNodeCommand" },
    { "$ref": "#/definitions/DeleteNodeCommand" },
    { "$ref": "#/definitions/ModifyNodeCommand" },
    { "$ref": "#/definitions/AttachScriptCommand" },
    { "$ref": "#/definitions/CreateSceneCommand" },
    { "$ref": "#/definitions/OpenSceneCommand" },
    { "$ref": "#/definitions/GetSceneInfoCommand" },
    { "$ref": "#/definitions/InspectSceneFileCommand" },
    { "$ref": "#/definitions/GetCurrentSceneDetailedCommand" },
    { "$ref": "#/definitions/SelectNodesCommand" },
    { "$ref": "#/definitions/FocusNodeCommand" },
    { "$ref": "#/definitions/PlayCommand" },
    { "$ref": "#/definitions/AddCommandPaletteCommand" },
    { "$ref": "#/definitions/SearchNodesByTypeCommand" },
    { "$ref": "#/definitions/SearchNodesByNameCommand" },
    { "$ref": "#/definitions/SearchNodesByGroupCommand" },
    { "$ref": "#/definitions/SearchNodesByScriptCommand" },
    { "$ref": "#/definitions/DuplicateNodeCommand" },
    { "$ref": "#/definitions/ReparentNodeCommand" },
    { "$ref": "#/definitions/RenameNodeCommand" },
    { "$ref": "#/definitions/AddToGroupCommand" },
    { "$ref": "#/definitions/RemoveFromGroupCommand" },
    { "$ref": "#/definitions/CaptureVisualContextCommand" },
    { "$ref": "#/definitions/GetVisualSnapshotCommand" },
    { "$ref": "#/definitions/EnableAutoVisualCaptureCommand" },
    { "$ref": "#/definitions/DisableAutoVisualCaptureCommand" },
    { "$ref": "#/definitions/StartDebugCaptureCommand" },
    { "$ref": "#/definitions/StopDebugCaptureCommand" },
    { "$ref": "#/definitions/ClearDebugOutputCommand" },
    { "$ref": "#/definitions/GetDebugOutputCommand" }
  ]
}

