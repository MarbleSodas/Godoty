# Godoty Tauri App - Environment Example

# LiteLLM Proxy (LLM Gateway) used by the backend
# Point the app to your running LiteLLM proxy URL and API key
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-proxy-example

# Optional: Choose agent backend implementation ("strands" | "letta")
# Defaults to "strands" until Letta migration is complete
AGENT_BACKEND=strands

# Legacy provider keys (not needed by the app once LiteLLM is used)
# These are typically required by the LiteLLM Proxy environment instead of the app:
# OPENROUTER_API_KEY=sk-openrouter-...
# ANTHROPIC_API_KEY=sk-ant-...

# Letta (MemGPT) settings (Phase 2)
# If you want Letta to route models via your LiteLLM proxy for unified telemetry/spend,
# configure your Letta server to use an OpenAI-compatible client with base_url=LITELLM_BASE_URL
# and an API key with access to your routed models. Then select a model handle below.
# LETTA_BASE_URL=http://localhost:8283
# LETTA_API_KEY=letta-example-key
# LETTA_ADE_MODE=true
# LETTA_MODEL=openai/gpt-4o-mini
# LETTA_EMBEDDING=openai/text-embedding-3-small


# Letta MCP Integration (Option B)
# Use Letta Desktop or Letta Server MCP settings to connect to these MCP servers from Godoty:
# - Plugin KB MCP: exposes tool plugin_kb.search(query, top_k?)
# - Docs KB MCP: exposes tool docs_kb.search(query, top_k?)
# - Project Context MCP: exposes tool get_project_context(select?)
# - Godot MCP: exposes tool run_godot_command(command)
# In Letta Desktop: Settings → MCP → Add servers pointing at your local MCP endpoints for the above.
# In Letta Server: configure MCP connectors so agents can call these tools directly.
